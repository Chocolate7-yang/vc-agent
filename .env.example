# 复制本文件为 .env 并填写
# run.sh 启动时会自动 source 项目根目录 .env

# ===== 网络 / SSL =====
# VPN/代理环境证书异常时可设为 true（开发环境常用）
ALLOW_INSECURE_SSL=true

# ===== LLM =====
# 仅使用 OpenAI 兼容配置（必填）
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ===== 飞书应用 =====
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 群聊 chat_id 或用户 open_id
FEISHU_RECEIVE_ID=
# 常用 chat_id
FEISHU_RECEIVE_ID_TYPE=chat_id
# 7x24 启动引导简报是否也推送（默认 0：仅定时简报推送）
FEISHU_PUSH_ON_BOOTSTRAP=0

# ===== 调度 =====
# 每日推送简报时间（北京时间）
BRIEF_HOUR=8
BRIEF_MINUTE=0
# 每隔 N 小时采集一次
PIPELINE_INTERVAL_HOURS=4


